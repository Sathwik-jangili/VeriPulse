{
  "name": "veripulse",
  "version": "1.0.0",
  "description": "AI-Powered Social Media Misinformation Detection System",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "flask": "cd .. && python backend/app.py",
    "dev:all": "concurrently -n flask,vite -c green,blue \"npm run flask\" \"npm run dev\"",
    "build": "vite build",
    "preview": "vite preview",
    "lint": "eslint . --ext js,jsx --report-unused-disable-directives --max-warnings 0"
  },
  "dependencies": {
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "lucide-react": "^0.39.0",
    "framer-motion": "^11.0.0",
    "recharts": "^2.8.0",
    "axios": "^1.6.0",
    "clsx": "^2.0.0",
    "react-hot-toast": "^2.4.0",
    "react-countup": "^6.4.0",
    "canvas-confetti": "^1.9.0",
    "@headlessui/react": "^1.7.0"
  },
  "devDependencies": {
    "@types/react": "^18.2.37",
    "@types/react-dom": "^18.2.15",
    "@vitejs/plugin-react": "^4.1.1",
    "vite": "^4.5.0",
    "eslint": "^8.53.0",
    "eslint-plugin-react": "^7.33.2",
    "eslint-plugin-react-hooks": "^4.6.0",
    "eslint-plugin-react-refresh": "^0.4.4",
    "autoprefixer": "^10.4.16",
    "postcss": "^8.4.31",
    "tailwindcss": "^3.3.5",
    "concurrently": "^8.2.2"
  }
}
